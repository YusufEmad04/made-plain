# ─── Required ─────────────────────────────────────────────────────
# 32+ char random string used to sign session cookies (HMAC-SHA256).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-me-with-a-32-char-min-random-string

# Public origin. Used for absolute URLs (sitemap, magic links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Persistence ──────────────────────────────────────────────────
# When unset, the app uses an in-memory store (good for local dev).
# When set, the app connects to MongoDB.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
# MONGODB_DB=made_plain

# ─── Storage ──────────────────────────────────────────────────────
# When S3_BUCKET is unset, the library serves placeholder text via
# /api/mock-download. When set, real S3 presigned URLs are used.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=

# ─── Email ────────────────────────────────────────────────────────
# When unset, sendEmail() logs to the server console (so dev magic
# links are visible without SMTP). When set, Resend delivers mail.
# RESEND_API_KEY=
# EMAIL_FROM=Made Plain <hello@madeplain.co>
